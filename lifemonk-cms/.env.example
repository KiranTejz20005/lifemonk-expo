HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Xano — required for sync and proxy
# Base URL for the default API group (used when XANO_COURSES_BASE_URL / XANO_MEMBERS_BASE_URL are not set)
XANO_BASE_URL=https://YOUR_INSTANCE.n7.xano.io/api:YOUR_GROUP

# Xano — optional: use different base URLs per API group
# Courses group (sync_course, chapter create/update). Defaults to XANO_BASE_URL if unset
# XANO_COURSES_BASE_URL=https://YOUR_INSTANCE.n7.xano.io/api:COURSES_GROUP
# Members & Accounts group (get_all_users, get_all_schools, get_all_grades). Defaults to XANO_BASE_URL if unset
# XANO_MEMBERS_BASE_URL=https://YOUR_INSTANCE.n7.xano.io/api:MEMBERS_GROUP

# Strapi public URL (used in sync for thumbnail URLs). Defaults to http://localhost:1337 if unset
STRAPI_URL=http://localhost:1337

# Xano API key — optional; set if your Xano endpoints require authentication
# XANO_API_KEY=

# Server-to-server — optional
# STRAPI_API_TOKEN=
