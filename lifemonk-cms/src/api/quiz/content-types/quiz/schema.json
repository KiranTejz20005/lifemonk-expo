{
  "kind": "collectionType",
  "collectionName": "quizzes",
  "info": {
    "singularName": "quiz",
    "pluralName": "quizzes",
    "displayName": "Quiz"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "chapter": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::chapter.chapter"
    },
    "pass_score": {
      "type": "integer",
      "default": 100
    },
    "questions": {
      "type": "json",
      "required": true
    },
    "xano_chapter_id": {
      "type": "integer"
    },
    "xano_quiz_id": {
      "type": "integer"
    }
  }
}
