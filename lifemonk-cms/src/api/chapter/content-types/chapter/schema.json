{
  "kind": "collectionType",
  "collectionName": "chapters",
  "info": {
    "singularName": "chapter",
    "pluralName": "chapters",
    "displayName": "Chapter"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "chapters"
    },
    "chapter_type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "video",
        "text",
        "quiz",
        "activity",
        "mixed"
      ]
    },
    "order": {
      "type": "integer",
      "required": true
    },
    "video_url": {
      "type": "string"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "content": {
      "type": "richtext"
    },
    "duration_minutes": {
      "type": "integer"
    },
    "is_locked": {
      "type": "boolean",
      "default": true
    },
    "lock_depends_on_order": {
      "type": "integer"
    },
    "activity_instructions": {
      "type": "richtext"
    },
    "activity_requires_proof": {
      "type": "boolean",
      "default": false
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "xano_course_id": {
      "type": "integer"
    },
    "xano_chapter_id": {
      "type": "integer"
    }
  }
}
