# Copy this file to .env and fill in your values. Do not commit .env.

# Strapi CMS (e.g. http://localhost:1337 or your server URL)
EXPO_PUBLIC_STRAPI_BASE_URL=http://localhost:1337

# Xano API base URLs (from your Xano project; do not commit real URLs)
EXPO_PUBLIC_XANO_AUTH_URL=
EXPO_PUBLIC_XANO_BASE_URL=

# Optional: Strapi API token for restricted content
# EXPO_PUBLIC_STRAPI_API_TOKEN=
